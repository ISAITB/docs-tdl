<?xml version="1.0" encoding="UTF-8"?>
<testcase id="AS2" xmlns="http://www.gitb.com/tdl/v1/" xmlns:gitb="http://www.gitb.com/core/v1/">
    <metadata>
        <gitb:name>AS2</gitb:name>
        <gitb:version>0.1</gitb:version>
        <gitb:description>Send an invoice as an AS2 message to a receiver access point after looking up the address of its Service Metadata Publisher from the Service Metadata Locator.</gitb:description>
		<gitb:type>CONFORMANCE</gitb:type>		
    </metadata>
    <namespaces>
    </namespaces>
    <imports>
        <artifact type="object" encoding="UTF-8" name="SMP_Metadata_Template">UBL_invoice_AS2/artifacts/peppol-smp-metadata-template.xml</artifact>
    </imports>
    <actors>
        <gitb:actor id="Sender_AS2" name="Sender_AS2" role="SUT" />
        <gitb:actor id="Receiver_AS2" name="Receiver_AS2" role="SIMULATED" />
        <gitb:actor id="ServiceMetadataPublisher" name="ServiceMetadataPublisher" role="SIMULATED" />
    </actors>
    <variables>
        <var name="smp_query_skipped" type="string" />
        <var name="smp_output" type="map"/>
        <var name="as2_output" type="map"/>
        <var name="as2_address" type="string" />
        <!-- Represents the type of document that the recipient is able to handle -->
        <var name="document_identifier" type="string">
            <value>urn:oasis:names:specification:ubl:schema:xsd:Invoice-2::Invoice##urn:www.cenbii.eu:transaction:biitrns010:ver2.0:extended:urn:www.peppol.eu:bis:peppol4a:ver2.0::2.1</value>
        </var>
        <!-- The identifier of the process -->
        <var name="process_identifier" type="string">
            <value>urn:www.cenbii.eu:profile:bii04:ver2.0</value>
        </var>
        <!-- XML local element name of the root-element in the business message -->
        <var name="business_message_type" type="string">
            <value>Invoice</value>
        </var>
        <var name="syntax" type="string" />
    </variables>
    <steps>
        <assign to="$as2_address">concat("https://", $Sender_AS2{Receiver_AS2}{network.host}, ":", $Sender_AS2{Receiver_AS2}{network.port})</assign>

        <if desc="If Access Point location is not cached">
            <cond>$Sender_AS2{ap.location.cached} != 'true'</cond>
            <then>
                <assign to="$smp_query_skipped">false</assign>
                <btxn from="Sender_AS2" to="ServiceMetadataPublisher" txnId="t1" handler="SMPFixedMessaging"/>
                <receive id="smp_output" desc="Send message to SMP to get Receiver Access Point address" from="Sender_AS2" to="ServiceMetadataPublisher" txnId="t1"/>
                <send desc="Return AP metadata" from="ServiceMetadataPublisher" to="Sender_AS2" txnId="t1">
                    <input name="smp_metadata" source="$SMP_Metadata_Template"/>
                </send>
                <etxn txnId="t1"/>
            </then>
            <else>
                <assign to="$smp_query_skipped">true</assign>
            </else>
        </if>

        <btxn from="Sender_AS2" to="Receiver_AS2" txnId="t2" handler="NonValidatingPeppolAS2Messaging"/>
        <receive id="as2_output" desc="Send message to Receiver Access Point" from="Sender_AS2" to="Receiver_AS2" txnId="t2" />
        <send id="mdn" desc="Send MDN back to Sender Access Point" from="Receiver_AS2" to="Sender_AS2" txnId="t2">
            <input name="http_headers" source="$as2_output{http_headers}" />
        </send>
        <etxn txnId="t2"/>

        <assign to="$syntax" source="$as2_output{business_header}">concat(substring('cii', 1 div number(boolean(contains(/*[local-name() = "StandardBusinessDocumentHeader"]/*[local-name() = "DocumentIdentification"]/*[local-name() = "Standard"]/text(), 'CrossIndustryInvoice')))), substring('ubl', 1 div number(not(boolean(contains(/*[local-name() = "StandardBusinessDocumentHeader"]/*[local-name() = "DocumentIdentification"]/*[local-name() = "Standard"]/text(), 'CrossIndustryInvoice'))))))</assign>

        <verify handler="http://einvoicing2.westeurope.cloudapp.azure.com:8000/invoice/api/validation?wsdl" desc="Validate invoice">
            <input name="xml">$as2_output{business_message}</input>
            <input name="type">$syntax</input>
        </verify>
    </steps>
</testcase>